# --- Model gateway (server-only) ---
# The recruiter-supplied metered key goes in the Vercel deployment.
# For local development you may use your own OpenRouter key instead.
OPENROUTER_API_KEY=
# Selected via ADR-007 benchmark; override without a code change.
OPENROUTER_MODEL=
# Response length cap per turn (bounded worst-case cost, ADR-006); default 600
OPENROUTER_MAX_TOKENS=600
# Fallback = benchmark runner-up (ADR-007); OpenRouter retries it if the primary errors
OPENROUTER_FALLBACK_MODEL=

# --- Rate limiting (ADR-006, server-only) ---
# These canonical names work everywhere. The Vercel Upstash-for-Redis
# integration instead injects UPSTASH_REDIS_KV_REST_API_URL/TOKEN (or bare
# KV_REST_API_URL/TOKEN); the limiter reads those as fallbacks, so a Vercel
# integration needs no manual aliasing.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Tunable caps
RATE_LIMIT_PER_IP_PER_MINUTE=10
RATE_LIMIT_GLOBAL_PER_DAY=400
# Per-IP daily cap on escalation submissions (ADR-005 spam control); default 3
RATE_LIMIT_ESCALATIONS_PER_IP_PER_DAY=3
# Per-IP daily cap on Delete-this-chat calls (ADR-008 hardening); default 20
RATE_LIMIT_DELETES_PER_IP_PER_DAY=20

# --- Escalations (ADR-005, server-only) ---
SUPABASE_URL=
SUPABASE_SECRET_KEY=
CONVERSATION_SIGNING_SECRET=
