# --- Model gateway (server-only) ---
# The recruiter-supplied metered key goes in the Vercel deployment.
# For local development you may use your own OpenRouter key instead.
OPENROUTER_API_KEY=
# Selected via ADR-007 benchmark; override without a code change.
OPENROUTER_MODEL=

# --- Rate limiting (ADR-006, server-only) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Tunable caps
RATE_LIMIT_PER_IP_PER_MINUTE=10
RATE_LIMIT_GLOBAL_PER_DAY=400

# --- Escalations (ADR-005, server-only) ---
SUPABASE_URL=
SUPABASE_SECRET_KEY=
